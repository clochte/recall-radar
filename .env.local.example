# Cron job protection (generate any random string)
CRON_SECRET=your-random-secret-here

# Google AdSense (replace with your publisher ID after approval)
NEXT_PUBLIC_ADSENSE_ID=ca-pub-PLACEHOLDER

# Your deployed URL (used for sitemap)
NEXT_PUBLIC_BASE_URL=https://recallradar.com
